{
  "name": "xrpl-group-pay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "pnpm check:env && pnpm check:mainnet-assets && pnpm check:mainnet-source-tag && pnpm check:mainnet-gate && pnpm check:mainnet-evidence && pnpm check:mainnet-acceptance && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:smoke": "storybook dev -p 6006 --ci --smoke-test --no-open --no-version-updates --disable-telemetry --quiet",
    "build-storybook": "storybook build --disable-telemetry",
    "check:env": "node scripts/check-env.mjs",
    "check:mainnet-assets": "node scripts/check-mainnet-assets.mjs",
    "check:mainnet-source-tag": "node scripts/check-mainnet-source-tag.mjs",
    "check:mainnet-gate": "node scripts/check-mainnet-gate.mjs",
    "check:mainnet-evidence": "node scripts/check-mainnet-release-evidence.mjs",
    "check:mainnet-acceptance": "node scripts/check-mainnet-acceptance.mjs",
    "import:mainnet-d1-evidence": "node scripts/import-mainnet-d1-provisioning-report.mjs",
    "import:mainnet-xaman-evidence": "node scripts/import-mainnet-xaman-attestation-report.mjs",
    "drill:mainnet-operations": "vitest run tests/mainnet-operational-stop-drill.test.ts --reporter=verbose",
    "db:migrate:local": "wrangler d1 migrations apply xrpl-group-pay-testnet --local",
    "db:migrations:list": "wrangler d1 migrations list xrpl-group-pay-testnet --local",
    "db:check:local": "node scripts/check-d1-receipt-schema.mjs",
    "build:worker": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:mainnet": "pnpm check:mainnet-assets && pnpm check:mainnet-source-tag && node scripts/check-mainnet-release-evidence.mjs --require-complete && node scripts/check-mainnet-acceptance.mjs --require-ready && node scripts/check-mainnet-gate.mjs --require-mainnet && opennextjs-cloudflare build && opennextjs-cloudflare deploy --env mainnet",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "validate": "pnpm db:migrate:local && pnpm db:check:local && pnpm check:mainnet-assets && pnpm check:mainnet-source-tag && pnpm check:mainnet-gate && pnpm check:mainnet-evidence && pnpm check:mainnet-acceptance && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "motion": "12.40.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.6.0",
    "xrpl": "5.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@playwright/test": "1.61.0",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/nextjs-vite": "10.4.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "storybook": "10.4.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20.19.0"
  }
}
