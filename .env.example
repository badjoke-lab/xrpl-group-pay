# Public application identity
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NETWORK=testnet

# Server-side network boundary. Must match NEXT_PUBLIC_APP_NETWORK.
APP_NETWORK=testnet

# A Mainnet build fails closed unless this is explicitly set to true.
ALLOW_MAINNET_BUILD=false

# Xaman Backend API credentials. Keep server-side only.
XAMAN_API_KEY=
XAMAN_API_SECRET=

# UInt32 tag used on Group Pay transactions. Use a non-production value on Testnet.
XRPL_SOURCE_TAG=
